{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "baseUrl": ".",

    "paths": {
      "@laytips/shared-types": ["packages/shared-types/dist"],
      "@laytips/filters": ["packages/filters/dist"],
      "@laytips/footystats": ["packages/footystats/dist"],
      "@laytips/race-engine": ["packages/race-engine/dist"]
    },

    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true
  }
}
